#include <iostream>
#include <array>
using namespace std;

int main() {
    int n;
    cin >> n;                                                 // считываем количество палочек

    array<int, 700> arr;                                     // массив для хранения длин (макс. 700)

    for (int i = 0; i < n; i++) {
        cin >> arr[i];                                       // заполняем массив длинами
    }

    int count = 0;                                           // счётчик найденных треугольников

    // перебираем все тройки палочек с уникальными индексами
    for (int a = 0; a < n - 2; a++) {                       
        for (int b = a + 1; b < n - 1; b++) {                
            for (int c = b + 1; c < n; c++) {

                // проверяем неравенство треугольника для текущей тройки
                if (arr[a] + arr[b] > arr[c] && 
                    arr[a] + arr[c] > arr[b] && 
                    arr[b] + arr[c] > arr[a]) {
                    count += 1;                              // увеличиваем счётчик, если треугольник возможен
                }
            } 
        }
    }

    cout << count << endl;                             

    return 0;
}