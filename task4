#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n, q;
    cin >> n >> q;                                              // считываем размер массива и количество запросов
    
    vector<long long> diff(n + 2, 0);                           // разностный массив (индексация с 1)
    vector<long long> result(n + 1, 0);                         // массив для результата

    // обрабатываем все запросы
    for (int i = 0; i < q; i++) {
        int l, r, v;
        cin >> l >> r >> v;                                     // считываем левую, правую границу и значение
        diff[l] += v;                                           // добавляем v начиная с l
        diff[r + 1] -= v;                                       // прекращаем добавлять после r
    }

    // восстанавливаем итоговый массив через префиксную сумму
    for (int i = 1; i <= n; i++) {
        result[i] = result[i - 1] + diff[i];                    // накапливаем сумму изменений
        cout << result[i] << " ";                               // выводим текущий элемент
    }
    
    return 0;
}