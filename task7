#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n, m, s;
    cin >> n >> m >> s;                                        // считываем количество вершин, рёбер и стартовую вершину

    vector<int> u(m), v(m);                                    // массивы для хранения рёбер
    vector<long long> w(m);                                    // веса рёбер

    for (int i = 0; i < m; i++) {
        cin >> u[i] >> v[i] >> w[i];                           // считываем ребро: из u в v с весом w
    }

    const long long INF = 1000000000000000000LL;               // константа бесконечности

    vector<long long> d(n + 1, INF);                           // массив расстояний (индексация с 1)
    d[s] = 0;                                                  // расстояние до стартовой вершины = 0

    // Алгоритм Форда-Беллмана
    for (int i = 1; i < n; i++) {
        for (int j = 0; j < m; j++) {
            
            // если ребро исходит из достижимой вершины и улучшает расстояние
            if (d[u[j]] != INF && d[u[j]] + w[j] < d[v[j]]) {
                d[v[j]] = d[u[j]] + w[j];                      // обновляем расстояние
            }
        }
    }

    // Проверка на отрицательный цикл
    for (int j = 0; j < m; j++) {
        if (d[u[j]] != INF && d[u[j]] + w[j] < d[v[j]]) {
            cout << "Negative cycle";                          // если расстояние улучшается - есть отрицательный цикл
            return 0;
        }
    }

    // Вывод ответа
    for (int i = 1; i <= n; i++) {
        if (d[i] == INF)
            cout << "inf";                                     // недостижимая вершина
        else
            cout << d[i];                                      // выводим расстояние

        if (i != n)
            cout << " ";                                       // пробел между числами
    }

    return 0;
}